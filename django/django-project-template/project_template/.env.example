# {{ project_name }} - environment variables (development defaults)
# Copy this file to .env and adjust as needed. Do NOT commit secrets.

DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY={{ secret_key }}
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_LOG_LEVEL=DEBUG

# Database (override when running outside Docker)
DATABASE_URL=postgres://postgres:postgres~1!@localhost:5432/{{ project_name }}
DB_NAME={{ project_name }}
DB_USER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_PASS=

# Production-only - leave blank in development
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_SSL_REDIRECT=false
