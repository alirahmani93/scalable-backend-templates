"""Base settings shared across every environment.

Environment-specific overrides live in sibling modules:
``development``, ``staging``, ``production`` and ``test``.

All values that depend on the runtime environment are loaded via
``python-decouple`` (``decouple.config``), which reads from a ``.env`` file
and/or the process environment so the same image / artifact can be
promoted across stages.
"""

from __future__ import annotations

from pathlib import Path
from typing import Final

from decouple import Csv, config


# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
# BASE_DIR points to the repository root (the directory containing ``src``).
BASE_DIR: Final[Path] = Path(__file__).resolve().parent.parent.parent
SRC_DIR: Final[Path] = BASE_DIR / "src"


# ---------------------------------------------------------------------------
# Core security
# ---------------------------------------------------------------------------
SECRET_KEY: Final[str] = config("DJANGO_SECRET_KEY", default="{{ secret_key }}")
DEBUG: Final[bool] = config("DJANGO_DEBUG", default=False, cast=bool)
ALLOWED_HOSTS: Final[list[str]] = config(
    "DJANGO_ALLOWED_HOSTS",
    default="localhost,127.0.0.1",
    cast=Csv(),
)


# ---------------------------------------------------------------------------
# Applications
# ---------------------------------------------------------------------------
DJANGO_APPS: Final[list[str]] = [
    "django.contrib.admin",
    "django.contrib.auth",
    "django.contrib.contenttypes",
    "django.contrib.sessions",
    "django.contrib.messages",
    "django.contrib.staticfiles",
]

THIRD_PARTY_APPS: Final[list[str]] = []

LOCAL_APPS: Final[list[str]] = []

INSTALLED_APPS: Final[list[str]] = DJANGO_APPS + THIRD_PARTY_APPS + LOCAL_APPS


# ---------------------------------------------------------------------------
# Middleware
# ---------------------------------------------------------------------------
MIDDLEWARE: Final[list[str]] = [
    "django.middleware.security.SecurityMiddleware",
    "django.contrib.sessions.middleware.SessionMiddleware",
    "django.middleware.common.CommonMiddleware",
    "django.middleware.csrf.CsrfViewMiddleware",
    "django.contrib.auth.middleware.AuthenticationMiddleware",
    "django.contrib.messages.middleware.MessageMiddleware",
    "django.middleware.clickjacking.XFrameOptionsMiddleware",
]

SITE_BASE_URL: Final[list[str]] = config(
    "SITE_BASE_URL",
    default="http://127.0.0.1:8000/",
    cast=Csv(),
)
CSRF_TRUSTED_ORIGINS: Final[list[str]] = config(
    "CSRF_TRUSTED_ORIGINS",
    default="",
    cast=Csv(),
)


# ---------------------------------------------------------------------------
# URL / WSGI / ASGI
# ---------------------------------------------------------------------------
ROOT_URLCONF: Final[str] = "config.urls"
WSGI_APPLICATION: Final[str] = "config.wsgi.application"
ASGI_APPLICATION: Final[str] = "config.asgi.application"


# ---------------------------------------------------------------------------
# Templates
# ---------------------------------------------------------------------------
TEMPLATES: Final[list[dict]] = [
    {
        "BACKEND": "django.template.backends.django.DjangoTemplates",
        "DIRS": [SRC_DIR / "templates"],
        "APP_DIRS": True,
        "OPTIONS": {
            "context_processors": [
                "django.template.context_processors.request",
                "django.contrib.auth.context_processors.auth",
                "django.contrib.messages.context_processors.messages",
            ],
        },
    },
]


# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASES: Final[dict] = {
    "default": {
        "ENGINE": "django.db.backends.postgresql",
        "NAME": config("DB_NAME"),
        "USER": config("DB_USER"),
        "HOST": config("DB_HOST"),
        "PORT": config("DB_PORT", cast=int),
        "PASSWORD": config("DB_PASS"),
        "CONN_MAX_AGE": config("CONN_MAX_AGE", default=0, cast=int),
    },
}


# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
AUTH_PASSWORD_VALIDATORS: Final[list[dict[str, str]]] = [
    {"NAME": "django.contrib.auth.password_validation.UserAttributeSimilarityValidator"},
    {"NAME": "django.contrib.auth.password_validation.MinimumLengthValidator"},
    {"NAME": "django.contrib.auth.password_validation.CommonPasswordValidator"},
    {"NAME": "django.contrib.auth.password_validation.NumericPasswordValidator"},
]


# ---------------------------------------------------------------------------
# Internationalization
# ---------------------------------------------------------------------------
LANGUAGE_CODE: Final[str] = config("DJANGO_LANGUAGE_CODE", default="en-us")
TIME_ZONE: Final[str] = config("DJANGO_TIME_ZONE", default="UTC")
USE_I18N: Final[bool] = True
USE_TZ: Final[bool] = True


# ---------------------------------------------------------------------------
# Static / media
# ---------------------------------------------------------------------------
STATIC_URL: Final[str] = "/static/"
STATIC_ROOT: Final[Path] = BASE_DIR / "staticfiles"
STATICFILES_DIRS: Final[list[Path]] = [SRC_DIR / "static"] if (SRC_DIR / "static").exists() else []

MEDIA_URL: Final[str] = "/media/"
MEDIA_ROOT: Final[Path] = BASE_DIR / "media"


# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
DEFAULT_AUTO_FIELD: Final[str] = "django.db.models.BigAutoField"


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL: Final[str] = config("DJANGO_LOG_LEVEL", default="INFO").upper()

LOGGING: Final[dict] = {
    "version": 1,
    "disable_existing_loggers": False,
    "formatters": {
        "verbose": {
            "format": "[{asctime}] {levelname} {name}:{lineno} {message}",
            "style": "{",
        },
    },
    "handlers": {
        "console": {
            "class": "logging.StreamHandler",
            "formatter": "verbose",
        },
    },
    "root": {
        "handlers": ["console"],
        "level": LOG_LEVEL,
    },
}
