# {{ project_name }} - .gitignore

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# --- Virtualenvs ---
.venv/
venv/
env/
ENV/

# --- Distribution / packaging ---
build/
dist/
wheels/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# --- Tests / coverage ---
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.cache/

# --- Type checkers / linters ---
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/

# --- Django ---
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
test-media/

# --- Environments ---
.env
.env.*
!.env.example

# --- Editors / IDEs ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Docker ---
docker/postgres_data/

# --- Node (in case of frontend assets) ---
node_modules/
