.env
.env.*
!.env.example

.venv/
venv/
__pycache__/
.mypy_cache/
.pytest_cache/
.ruff_cache/

build/
dist/
*.egg-info/

staticfiles/
media/
db.sqlite3
db.sqlite3-journal

docker/postgres_data/

# Generated migrations are usually fine to share, but secret fixtures are not:
**/fixtures/secrets/
